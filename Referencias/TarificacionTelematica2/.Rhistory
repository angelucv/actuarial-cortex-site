library(osmdata)
library(osmdata)
library(sf)
library(sf)
library(dplyr)
# Definir la región de interés (Caracas)
place_name <- "Caracas, Venezuela"
bb <- getbb(place_name) # Obtener el 'bounding box'
# CRS proyectado para Venezuela (UTM Zone 20N)
crs_utm <- st_crs(32620)
# 1. Obtener la red vial
q_roads <- opq(bbox = bb) %>%
add_osm_feature(key = "highway")
# Descargar los datos, puede tomar tiempo
osm_roads <- osmdata_sf(q_roads)
# Descargar los datos, puede tomar tiempo
osm_roads <- osmdata_sf(q_roads)
roads_sf <- osm_roads$osm_lines %>%
st_transform(crs_utm)
cat(sprintf("Red vial para %s obtenida. Número de tramos: %d\n", place_name, nrow(roads_sf)))
# 2. Obtener Puntos de Interés (POIs) - ej. bares y escuelas
q_pois <- opq(bbox = bb) %>%
add_osm_feature(key = "amenity", value = c("bar", "pub", "nightclub", "school", "kindergarten"))
osm_pois <- osmdata_sf(q_pois)
# Combinar puntos y polígonos de POIs
pois_sf <- bind_rows(
osm_pois$osm_points %>% select(osm_id, amenity),
st_centroid(osm_pois$osm_polygons) %>% select(osm_id, amenity)
) %>%
st_transform(crs_utm)
cat(sprintf("POIs para %s obtenidos. Número de POIs: %d\n", place_name, nrow(pois_sf)))
# 3. Obtener huellas de edificios
q_buildings <- opq(bbox = bb) %>%
add_osm_feature(key = "building")
osm_buildings <- osmdata_sf(q_buildings)
osm_buildings <- osmdata_sf(q_buildings)
buildings_sf <- osm_buildings$osm_polygons %>%
st_transform(crs_utm)
cat(sprintf("Edificios para %s obtenidos. Número de edificios: %d\n", place_name, nrow(buildings_sf)))
