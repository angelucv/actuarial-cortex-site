#| label: fig-expected-utility-comparison-py-setup
#| include: false
#| echo: false
#| results: hide
#| warning: false
#| message: false
import numpy as np
import plotly.graph_objects as go
import plotly.io as pio
pio.renderers.default = "jupyterlab"
# Parámetros del ejemplo
W0 = 1000 # Riqueza inicial
L = 400   # Pérdida potencial
p = 0.5   # Probabilidad de pérdida
# Función de utilidad (aversa al riesgo, logarítmica)
U = lambda x: np.log(x + 1)
# Riqueza en los dos estados
W_no_loss = W0
W_loss = W0 - L
# Valor esperado de la riqueza (E[X])
EX = (1 - p) * W_no_loss + p * W_loss
# Utilidad de los resultados individuales
U_W_no_loss = U(W_no_loss)
U_W_loss = U(W_loss)
# Utilidad esperada (E[U(X)])
EUX = (1 - p) * U_W_no_loss + p * U_W_loss
# Equivalente de Certeza (CE) - para la ilustración
CE = np.exp(EUX) - 1
# Rango para la curva de utilidad
x_range = np.linspace(W_loss - 50, W_no_loss + 50, 200)
x_range = x_range[x_range > 0] # Asegurar valores positivos para log
fig_eu_comp = go.Figure()
# Curva de utilidad
fig_eu_comp.add_trace(go.Scatter(x=x_range, y=U(x_range), mode='lines', name='Función de Utilidad <span class="math-inline">U\(x\)</span>',
line=dict(color='blue', width=2)))
# Puntos de riqueza con y sin pérdida
fig_eu_comp.add_trace(go.Scatter(x=[W_loss, W_no_loss], y=[U_W_loss, U_W_no_loss], mode='markers',
name='Resultados de Riqueza',
marker=dict(size=10, color='red')))
# Cuerda que une las utilidades de los resultados
fig_eu_comp.add_trace(go.Scatter(x=[W_loss, W_no_loss], y=[U_W_loss, U_W_no_loss], mode='lines',
name='Cuerda de Utilidades',
line=dict(color='red', dash='dash')))
# Punto de Valor Esperado de la Riqueza en el Eje X
fig_eu_comp.add_vline(x=EX, line_dash="dot", line_color="purple", annotation_text=f"E[X]={int(EX)}", annotation_position="bottom left")
# Punto de Utilidad Esperada en la Cuerda y en el Eje Y
fig_eu_comp.add_trace(go.Scatter(x=[EX], y=[EUX], mode='markers', name='Utilidad Esperada <span class="math-inline">E\[U\(X\)\]</span>',
marker=dict(size=12, color='green', symbol='star')))
fig_eu_comp.add_hline(y=EUX, line_dash="dot", line_color="green", annotation_text=f"E[U(X)]={EUX:.2f}", annotation_position="top right")
# Punto de Utilidad de la Riqueza Esperada en la Curva
fig_eu_comp.add_trace(go.Scatter(x=[EX], y=[U(EX)], mode='markers', name='Utilidad de Riqueza Esperada <span class="math-inline">U\(E\[X\]\)</span>',
marker=dict(size=12, color='orange', symbol='circle-open')))
fig_eu_comp.update_layout(
title="Utilidad Esperada vs. Utilidad de la Riqueza Esperada (Aversor al Riesgo)",
xaxis_title="Riqueza (x)",
yaxis_title="Utilidad U(x)",
hovermode="x unified",
showlegend=True
)
#| label: fig-expected-utility-comparison-py-display
#| fig-cap: "Comparación de Utilidad Esperada vs. Utilidad de Riqueza Esperada"
#| echo: false
fig_eu_comp
#| label: fig-utility-attitudes-py-setup
#| include: false
#| echo: false
#| results: hide
#| warning: false
#| message: false
import numpy as np
import plotly.graph_objects as go
import plotly.io as pio
pio.renderers.default = "jupyterlab"
# Rango de riqueza
x_attitudes = np.linspace(1, 10, 100) # Usar un rango más pequeño para ilustrar la forma
# Funciones de utilidad típicas
U_averse = lambda w: np.log(w)
U_neutral = lambda w: w
U_lover = lambda w: w**2
fig_attitudes = go.Figure()
fig_attitudes.add_trace(go.Scatter(x=x_attitudes, y=U_averse(x_attitudes), mode='lines', name='Averso al Riesgo (<span class="math-inline">U\(x\) \= \\ln\(x\)</span>)', line=dict(color='blue')))
fig_attitudes.add_trace(go.Scatter(x=x_attitudes, y=U_neutral(x_attitudes), mode='lines', name='Neutral al Riesgo (<span class="math-inline">U\(x\) \= x</span>)', line=dict(color='green')))
fig_attitudes.add_trace(go.Scatter(x=x_attitudes, y=U_lover(x_attitudes), mode='lines', name='Buscador de Riesgo (<span class="math-inline">U\(x\) \= x^2</span>)', line=dict(color='red')))
# Ilustrar una lotería simple (ej. ganar 2 con 0.5, perder 2 con 0.5, desde una riqueza de 5)
W_initial_lottery = 5
W_outcome1 = W_initial_lottery - 2 # 3
W_outcome2 = W_initial_lottery + 2 # 7
p_lottery = 0.5
EX_lottery = (p_lottery * W_outcome1) + ((1 - p_lottery) * W_outcome2) # 0.5*3 + 0.5*7 = 5
# Add points for a neutral individual's lotteries
fig_attitudes.add_trace(go.Scatter(x=[W_outcome1, W_outcome2], y=[U_neutral(W_outcome1), U_neutral(W_outcome2)],
mode='markers', name='Resultados Lotería',
marker=dict(color='black', size=8)))
fig_attitudes.add_trace(go.Scatter(x=[W_outcome1, W_outcome2], y=[U_neutral(W_outcome1), U_neutral(W_outcome2)],
mode='lines', line=dict(dash='dash', color='black', width=1), showlegend=False))
fig_attitudes.add_trace(go.Scatter(x=[EX_lottery], y=[U_neutral(EX_lottery)], mode='markers', name='E[X] y U(E[X]) para Neutral',
marker=dict(color='darkgreen', size=10, symbol='star')))
fig_attitudes.add_trace(go.Scatter(x=[EX_lottery], y=[(p_lottery * U_neutral(W_outcome1)) + ((1-p_lottery) * U_neutral(W_outcome2))],
mode='markers', name='E[U(X)] para Neutral',
marker=dict(color='darkgreen', size=10, symbol='circle-open'), showlegend=False)) # Coincide con U(E[X])
fig_attitudes.update_layout(
title="Actitudes frente al Riesgo",
xaxis_title="Riqueza (x)",
yaxis_title="Utilidad U(x)",
hovermode="x unified",
showlegend=True
)
#| label: fig-utility-attitudes-py-display
#| fig-cap: "Actitudes frente al Riesgo (Aversión, Neutralidad, Afinidad)"
#| echo: false
fig_attitudes
